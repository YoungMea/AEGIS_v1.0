# =====================================================
# AEGIS Intelligence Platform — Environment Variables
# =====================================================

# --- Authentication ---
# Generate a strong secret: `openssl rand -hex 64`
JWT_SECRET=replace-me-with-a-long-random-secret-string-of-at-least-64-chars
JWT_EXPIRES_IN=7d

# --- NoLook encryption ---
# Master key for AES-256-GCM at-rest encryption (dossiers + chat).
# Generate with: `openssl rand -hex 64`
# If left empty, NoLook derives a key from JWT_SECRET. For maximum protection
# (DB leaked but env file untouched) use a SEPARATE secret here.
NOLOOK_KEY=

# --- Database ---
# SQLite path (relative to project root). Default works out of the box.
DATABASE_URL=./data/aegis.db

# --- OTP delivery channel ---
# Options:
#   simulate  → returns the OTP in the API response (educational only)
#   telegram  → sends OTP through @Aegis_verification_bot (recommended)
#   sms       → sends OTP through Twilio (requires Twilio creds below)
OTP_CHANNEL=telegram
OTP_LENGTH=6
OTP_TTL_SECONDS=300

# --- Telegram Bot ---
# Get a token from @BotFather, then create a bot and put it here.
TELEGRAM_BOT_TOKEN=8624274400:AAEkeRorCD4HVgGb3aSPaYZv-5JfX6gBlbY
# Bot username WITHOUT the @ — used to build the deep-link tg://t.me/<username>
TELEGRAM_BOT_USERNAME=Aegis_verification_bot

# Support bot — used by the in-app Support section. Create a separate bot
# in @BotFather (e.g. AegisSupport_bot) and put its username here (no @).
NEXT_PUBLIC_TELEGRAM_SUPPORT_BOT_USERNAME=

# --- Twilio (only used when OTP_CHANNEL=sms) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Security ---
# Bcrypt cost factor (10–12 recommended)
BCRYPT_ROUNDS=12

# --- Public ---
NEXT_PUBLIC_AGENCY_NAME=AEGIS
NEXT_PUBLIC_AGENCY_FULL=Advanced Electronic General Intelligence Service
# Public bot username, available in client components for the "Open bot" button.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=Aegis_verification_bot
